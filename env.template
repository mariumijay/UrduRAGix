# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Urdu RAG System — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── LLM Configuration ─────────────────────────────────────────────────────────
# Groq API Keys (support key rotation)
GROQ_API_KEY_1="gsk_your_first_key_here"
GROQ_API_KEY_2="gsk_your_second_key_here"
GROQ_API_KEY_3="gsk_your_third_key_here"
# Fallback single key (if no GROQ_API_KEY_N found)
GROQ_API_KEY="gsk_your_fallback_key"

# LLM Model selection
LLM_MODEL="qwen/qwen3-32b"

# ─── Embedding Configuration ──────────────────────────────────────────────────
# Sentence transformer model for embeddings
EMBEDDING_MODEL="intfloat/multilingual-e5-base"

# ─── Reranking Configuration ──────────────────────────────────────────────────
# Cross-encoder model for reranking
RERANKER_MODEL="cross-encoder/mmarco-mMiniLMv2-L12-H384-v1"

# ─── Retrieval Configuration ──────────────────────────────────────────────────
# Number of dense vectors to retrieve before fusion
TOP_K_DENSE=20

# Number of sparse (BM25) results to retrieve before fusion
TOP_K_SPARSE=20

# Final number of results after reranking
TOP_K_FINAL=20

# ─── Logging Configuration ────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Optional: Hugging Face (if using HF models) ──────────────────────────────
# HuggingFace API key (optional, for downloading models)
# HF_TOKEN="hf_your_token_here"

# ─── Optional: Google Drive (if syncing datasets) ───────────────────────────
# GOOGLE_DRIVE_FOLDER_ID="your_folder_id_here"

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Notes:
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 1. Groq API Keys: The system supports key rotation. If GROQ_API_KEY_1, 
#    GROQ_API_KEY_2, etc. are found, they'll be used in order.
#
# 2. LLM Model: Currently set to qwen/qwen3-32b. Other options:
#    - qwen/qwen3-72b (larger, slower)
#    - llama2-70b-chat
#    - mixtral-8x7b-32768
#
# 3. Embedding Model: intfloat/multilingual-e5-base is optimized for Urdu.
#    For faster but less accurate embeddings, use:
#    - sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
#
# 4. Reranker: The cross-encoder provides semantic relevance scoring.
#    Disable in prompt_b.py RETRIEVAL_CONFIG if speed is critical.
#
# 5. Retrieval: TOP_K_DENSE and TOP_K_SPARSE control pre-fusion results.
#    Higher values = better recall but slower retrieval.
#    TOP_K_FINAL = results after reranking (typically 3-5).
#
# 6. Before running:
#    python preprocess.py --book data/book.txt --title "کتاب" --author "مصنف"
#    python -m ingestion.ingest_b data/urdu_B/
#    python main.py
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
